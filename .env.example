# Application
APP_ENV=development
APP_VERSION=2.0.0
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8001
CORS_ORIGINS=http://localhost:8001,http://127.0.0.1:8001
UVICORN_WORKERS=1

# Required: Compass API endpoint
# These values are the runtime defaults — copy this file to `.env` and update
# OPENAI_API_KEY with your own key. No defaults are hardcoded in source.
#OPENAI_API_KEY=your-compass-api-key-here
OPENAI_BASE_URL=https://api.core42.ai/v1

# Required: Compass model selection (no hardcoded fallbacks in source)
COMPASS_CHAT_MODEL=gpt-4.1
COMPASS_REASONING_MODEL=gpt-5.1
COMPASS_EMBEDDING_MODEL=text-embedding-3-large
COMPASS_WHISPER_MODEL=whisper-1
SAMPLE_MODE=false

# Optional: supplemental search via CourtListener (CAP data is hosted there)
COURTLISTENER_API_TOKEN=
COURTLISTENER_API_BASE=https://www.courtlistener.com/api/rest/v4

# Paths
LEGAL_DATA_DIR=./data
LEGAL_LOGS_DIR=./logs
LEGAL_CHECKPOINT_DIR=./logs/checkpoints

# Retrieval tuning
MAX_PRECEDENTS=8
SIMILARITY_THRESHOLD=0.12

# Critique loop
MAX_REVISIONS=2
CRITIQUE_APPROVAL_THRESHOLD=70
# Below this score the critic escalates to the supervisor for human review.
ESCALATION_QUALITY_THRESHOLD=40

